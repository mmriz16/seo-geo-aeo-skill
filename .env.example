# SEO-GEO-AEO Skill — Environment Variables
# Copy to .env and fill in your keys

# Google PageSpeed Insights API key
# Get one: https://console.cloud.google.com/apis/credentials
# Enable: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
# Without this: 240 queries/day rate limit
# With this: 25,000 queries/day
PAGESPEED_API_KEY=
